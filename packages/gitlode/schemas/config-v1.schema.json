{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/gitlode/gitlode/schemas/config-v1.schema.json",
  "title": "gitlode configuration v1",
  "description": "Schema for gitlode --config files (version 1).",
  "type": "object",
  "properties": {
    "version": {
      "type": "number",
      "const": 1
    },
    "extraction": {
      "type": "object",
      "properties": {
        "refs": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "range": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "sinceRef": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "sinceRef"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "sinceDate": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "sinceDate"
              ],
              "additionalProperties": false
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "properties": {
        "directory": {
          "type": "string",
          "minLength": 1
        },
        "prefix": {
          "type": "string",
          "minLength": 1
        },
        "rotation": {
          "type": "object",
          "properties": {
            "lines": {
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            },
            "size": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "repository": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "runtime": {
      "type": "object",
      "properties": {
        "profile": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "extensions": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "entrypoint": {
            "type": "string",
            "minLength": 1
          },
          "config": {},
          "failurePolicy": {
            "default": "skip-fact",
            "type": "string",
            "enum": [
              "skip-fact",
              "fatal"
            ]
          }
        },
        "required": [
          "entrypoint"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "version"
  ],
  "additionalProperties": false
}
