{
  "name": "@gitlode/root",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/gitlode",
    "packages/plugin-assay-metrics",
    "packages/plugin-conventional-commits",
    "packages/plugin-custom-field",
    "packages/plugin-file-type",
    "packages/plugin-identity-profile"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:watch": "npm run build:watch -w packages/gitlode",
    "changeset": "changeset",
    "changeset:publish": "changeset publish",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "format": "node -e \"console.error('Error: Please run format:check or format:write instead.'); process.exit(1)\"",
    "format:check": "npm run format:check --workspaces --if-present",
    "format:write": "npm run format:write --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "lockfile:sync": "npm install --package-lock-only --ignore-scripts",
    "release": "npm run build && npm run changeset:publish",
    "test": "npm test --workspaces --if-present",
    "test:watch": "npm run test:watch -w packages/gitlode",
    "test:coverage": "npm run test:coverage -w packages/gitlode",
    "version-packages": "npm run changeset:version && npm run lockfile:sync"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.13.14",
    "@vitest/coverage-v8": "^4.1.10",
    "memfs": "^4.64.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
