{
  // Terminal
  "terminal.integrated.env.windows": {
    "LANG": "en_US.UTF-8"
  },
  // AI / chat
  "chat.disableAIFeatures": false,
  "github.copilot.enable": {
    "*": true
  },
  // Dictonary
  "cSpell.words": ["gitrail"],

  // Formatter
  "[json]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "json.format.enable": false
}
