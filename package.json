{
  "name": "@gitlode/root",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/gitlode",
    "packages/plugin-conventional-commits",
    "packages/plugin-custom-field"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:watch": "npm run build:watch -w packages/gitlode",
    "changeset": "changeset",
    "format": "node -e \"console.error('Error: Please run format:check or format:write instead.'); process.exit(1)\"",
    "format:check": "npm run format:check --workspaces --if-present",
    "format:write": "npm run format:write --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "release": "changeset publish",
    "test": "npm test --workspaces --if-present",
    "test:watch": "npm run test:watch -w packages/gitlode",
    "test:coverage": "npm run test:coverage -w packages/gitlode",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.13.14",
    "@vitest/coverage-v8": "^4.1.8",
    "memfs": "^4.57.3",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
