{
  // Terminal
  "terminal.integrated.env.windows": {
    "LANG": "en_US.UTF-8"
  },

  // AI / chat
  "chat.disableAIFeatures": false,
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": true,
    "typescript": true
  },

  // Dictonary
  "cSpell.words": [
    "citty",
    "gitload",
    "gitlode",
    "gitrail",
    "libgit",
    "nodegit",
    "oids",
    "oxfmt",
    "oxlint",
    "touchpoint",
    "Touchpoints",
    "yieldable"
  ],

  // Formatter
  "editor.defaultFormatter": "oxc.oxc-vscode"
}
